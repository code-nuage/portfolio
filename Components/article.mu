<div class="card grid-col-4">
    <div class="text-container">
        <div class="text-characteristics">
            <h4 class="text-weight-bold">{{data:title}}</h4>
            <span>{{data:flag}}</span>
        </div>
        <span><code>{{data:date}}</code></span>
    </div>
    <a class="btn full-width" href="{{data:article_link}}">Read article</a>
</div>