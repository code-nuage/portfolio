<div class="card grid-col-4">
    <img src="{{data:image_link}}" alt="{{data:image_alt}}">
    <div class="bottom">
        <div class="text-container">
            <h4 class="text-weight-bold">{{data:title}}</h4>
            <p>{{data:description_short}}</p>
        </div>
        <ul class="tags grid-spacing-2">
            {{data:tags}}
        </ul>
        <a class="btn full-width" href="{{data:project_link}}">Learn more</a>
    </div>
</div>